{
  "schema_version": "2.0",
  "name": "Total area of concrete slabs",
  "description": "Sum the area of every concrete slab.",
  "output_mode": "aggregate",
  "result_unit": "m2",
  "tags": ["slabs", "qto"],
  "selector": {
    "kind": "and",
    "children": [
      {"kind": "category", "values": ["Floors", "Slabs"]},
      {"kind": "ifc_class", "values": ["IfcSlab"]}
    ]
  },
  "predicate": {
    "kind": "triplet",
    "attribute": {"kind": "exact", "pset_name": "Pset_SlabCommon", "name": "Material"},
    "constraint": {"operator": "contains", "value": "Concrete", "case_sensitive": false}
  },
  "formula": "Area"
}
