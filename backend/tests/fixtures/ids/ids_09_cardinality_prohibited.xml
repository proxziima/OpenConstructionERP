<?xml version="1.0" encoding="UTF-8"?>
<ids:ids xmlns:ids="http://standards.buildingsmart.org/IDS"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://standards.buildingsmart.org/IDS IDS-1.0.xsd">
  <ids:info>
    <ids:title>No legacy Phase property on beams</ids:title>
    <ids:copyright>OpenConstructionERP test fixtures</ids:copyright>
    <ids:version>1.0.0</ids:version>
    <ids:description>Pset_Legacy.Phase is PROHIBITED on IfcBeam — its presence is a failure.</ids:description>
    <ids:author>fixtures@openconstructionerp.io</ids:author>
    <ids:date>2026-04-25</ids:date>
  </ids:info>
  <ids:specifications>
    <ids:specification name="Beam Phase prohibited" ifcVersion="IFC4" identifier="ids_09">
      <ids:applicability minOccurs="1" maxOccurs="unbounded">
        <ids:entity>
          <ids:name>
            <ids:simpleValue>IFCBEAM</ids:simpleValue>
          </ids:name>
        </ids:entity>
      </ids:applicability>
      <ids:requirements>
        <ids:property cardinality="prohibited">
          <ids:propertySet>
            <ids:simpleValue>Pset_Legacy</ids:simpleValue>
          </ids:propertySet>
          <ids:baseName>
            <ids:simpleValue>Phase</ids:simpleValue>
          </ids:baseName>
        </ids:property>
      </ids:requirements>
    </ids:specification>
  </ids:specifications>
</ids:ids>
