  "display_name": "LV-Qualität (Leistungsverzeichnis)",
  "name": "Leistungsverzeichnis-Qualitätsregeln",
  "description": "Deutsches BOQ-Quality-Set, abgestimmt auf die LV-Struktur (Titel → Position → Teilleistung) nach VOB/A § 7 und GAEB-Konvention. Spiegelt 'boq_quality' mit deutsch-spezifischen Prüfungen: OZ-Hierarchie, Mengen-/Einheits-Plausibilität, Einheitspreis-Sanity in EUR, Kurz-/Langtext-Vollständigkeit, Bedarfs-/Eventual-/Stundenlohn-Markierung.",
  "standard": "VOB/A § 7 (Leistungsbeschreibung) + GAEB-Konvention",
  "jurisdiction": "DE",
  "severity_default": "error",
  "category": "quality",
  "locale_default": "de",
  "enables_rule_ids": [
    "boq_quality.position_has_quantity",
    "boq_quality.position_has_unit_rate",
    "boq_quality.position_has_description",
    "boq_quality.no_duplicate_ordinals",
    "boq_quality.unit_rate_in_range",
    "boq_quality.negative_values",
    "boq_quality.unrealistic_rate",
    "boq_quality.total_mismatch",
    "boq_quality.empty_unit",
    "boq_quality.unit_system_consistency",
    "boq_quality.currency_consistency",
    "boq_quality.measurement_consistency",
    "boq_quality.section_without_items",
    "boq_quality.rate_vs_benchmark",
    "boq_quality.lump_sum_ratio",
    "boq_quality.cost_concentration",
    "lv.titel_present",
    "lv.titel_hierarchy_3_levels_max",
    "lv.position_under_titel",
    "lv.teilleistung_under_position",
    "lv.oz_format_din_276_aligned",
    "lv.kurztext_max_60_chars",
    "lv.langtext_required_for_priced_positions",
    "lv.einheit_din_iec_format",
    "lv.einheit_metric_only",
    "lv.einheitspreis_currency_eur",
    "lv.gesamtsumme_brutto_mwst_19",
    "lv.nachlass_documented",
    "lv.bedarfsposition_marked",
    "lv.eventualposition_marked",
    "lv.stundenlohnarbeiten_marked",
    "lv.zulage_position_linked_to_main",
    "lv.mengenansatz_documented_per_position"
