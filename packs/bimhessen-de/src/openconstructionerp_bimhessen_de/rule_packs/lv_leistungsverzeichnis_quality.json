  "metadata": {
    "structure": ["Titel (Level 1)", "Position (Level 2)", "Teilleistung / Unter­leistungsposition (Level 3)"],
    "ordinal_convention": "OZ — e.g. '01.02.0030.A' (Titel.SubTitel.Position.Teilleistung)",
    "currency": "EUR",
    "mwst_default": "19 %",
    "references": [
      "VOB/A § 7 Leistungsbeschreibung",
      "GAEB DA XML 3.3 LV-Struktur",
      "DIN 276:2018-12 KG-Zuordnung"
    ]
  }
