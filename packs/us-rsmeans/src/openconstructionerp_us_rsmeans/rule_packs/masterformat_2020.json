{
  "rule_pack_id": "masterformat_2020",
  "name": "CSI MasterFormat 2020 — 50 Division Structure",
  "standard": "CSI MasterFormat 2020",
  "jurisdiction": "US",
  "edition": "2020 (Numbers & Titles)",
  "description": "Enables OCERP built-in validation rules that enforce the CSI MasterFormat 2020 numbering scheme (Level 1 Division 'NN', Level 2 Section 'NN NN', Level 3 Subsection 'NN NN NN', up to Level 4 'NN NN NN.NN'), section title presence, mandatory descriptions, and Division completeness checks per project type (commercial new build, renovation, civil/sitework).",
  "issuer": "Construction Specifications Institute (CSI) & Construction Specifications Canada (CSC)",
  "covers_divisions": "00-14, 21-28, 31-35, 40-48 (50 numbered Divisions, 'reserved' bands documented)",
  "enables_rule_ids": [
    "masterformat.division_code_valid",
    "masterformat.division_code_in_active_range",
    "masterformat.section_code_format_valid",
    "masterformat.subsection_code_format_valid",
    "masterformat.level_4_code_format_valid",
    "masterformat.section_title_required",
    "masterformat.description_required",
    "masterformat.uom_imperial_or_metric",
