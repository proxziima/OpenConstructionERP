    "masterformat.division_08_openings_completeness",
    "masterformat.division_09_finishes_completeness",
    "masterformat.division_21_fire_suppression_completeness",
    "masterformat.division_22_plumbing_completeness",
    "masterformat.division_23_hvac_completeness",
    "masterformat.division_26_electrical_completeness",
    "masterformat.division_27_communications_completeness",
    "masterformat.division_28_electronic_safety_security_completeness",
    "masterformat.division_31_earthwork_completeness",
    "masterformat.division_32_exterior_improvements_completeness",
    "masterformat.division_33_utilities_completeness",
    "masterformat.no_orphan_sections",
    "masterformat.no_duplicate_section_codes"
